# Server
PORT=5000
NODE_ENV=development

# MongoDB — paste URI from Heramb into your local .env (never commit .env)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-to-a-different-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173
