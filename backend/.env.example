# Server
PORT=5000
NODE_ENV=development

# MongoDB — paste URI from Heramb into your local .env (never commit .env)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-to-a-different-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

# Seed data (optional — used by npm run seed:branch)
SEED_BRANCH_NAME=Main Salon Branch
SEED_BRANCH_ADDRESS=Salon address — update after client meeting
SEED_BRANCH_PHONE=

# Dev owner user (optional — used by npm run seed:owner / seed:dev)
# Default password is documented in README.md only — do not commit real passwords here.
SEED_OWNER_NAME=Salon Owner
SEED_OWNER_PHONE=9999999999
SEED_OWNER_EMAIL=owner@salon.dev
# SEED_OWNER_PASSWORD=set-locally-if-you-need-a-custom-dev-password
